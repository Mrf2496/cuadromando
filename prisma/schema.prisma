// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// PLAN ESTRATÉGICO GENERAL
// ============================================
model StrategicPlan {
  id              String   @id @default(cuid())
  name            String
  startDate       DateTime
  endDate         DateTime
  description     String?
  status          String   @default("active") // active, paused, completed, cancelled
  generalResponsible String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  perspectives    Perspective[]
  teams           Team[]
  employees       Employee[]
  alerts          Alert[]
  backups         Backup[]
  scenarios       Scenario[]
}

// ============================================
// PERSPECTIVAS (6 configurables)
// ============================================
model Perspective {
  id              String   @id @default(cuid())
  strategicPlanId String
  name            String
  description     String?
  color           String   @default("#3b82f6")
  weight          Float    @default(0) // Porcentaje estratégico
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  strategicPlan   StrategicPlan @relation(fields: [strategicPlanId], references: [id], onDelete: Cascade)
  objectives      StrategicObjective[]
}

// ============================================
// OBJETIVOS ESTRATÉGICOS
// ============================================
model StrategicObjective {
  id              String   @id @default(cuid())
  perspectiveId   String
  code            String   // Código automático (ej: OBJ-001)
  description     String
  weight          Float    @default(0)
  targetDate      DateTime?
  responsible     String?
  status          String   @default("active") // active, completed, at_risk, delayed
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  perspective     Perspective @relation(fields: [perspectiveId], references: [id], onDelete: Cascade)
  policies        Policy[]
  corporateGoals  CorporateGoal[]
  strategies      CorporateStrategy[]
  kpis            CorporateKPI[]
  actionPlans     ActionPlan[]
}

// ============================================
// POLÍTICAS
// ============================================
model Policy {
  id              String   @id @default(cuid())
  objectiveId     String
  code            String   // Código automático
  description     String
  status          String   @default("active") // active, inactive, completed
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  objective       StrategicObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
}

// ============================================
// METAS CORPORATIVAS
// ============================================
model CorporateGoal {
  id              String   @id @default(cuid())
  objectiveId     String
  indicator       String
  targetValue     Float
  currentValue    Float    @default(0)
  unit            String
  targetDate      DateTime?
  progress        Float    @default(0) // Avance automático %
  status          String   @default("on_track") // on_track, at_risk, delayed, completed
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  objective       StrategicObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  actionPlans     ActionPlan[]
}

// ============================================
// ESTRATEGIAS CORPORATIVAS
// ============================================
model CorporateStrategy {
  id              String   @id @default(cuid())
  objectiveId     String
  code            String   // Código automático
  description     String
  type            String   @default("growth") // growth, control, efficiency, innovation, other
  status          String   @default("active") // active, completed, cancelled
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  objective       StrategicObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  actionPlans     ActionPlan[]
}

// ============================================
// KPI CORPORATIVOS
// ============================================
model CorporateKPI {
  id              String   @id @default(cuid())
  objectiveId     String
  name            String
  formula         String?
  frequency       String   @default("monthly") // daily, weekly, monthly, quarterly, yearly
  currentValue    Float    @default(0)
  targetValue     Float    @default(100)
  trafficLight    String   @default("green") // green, yellow, red
  unit            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  objective       StrategicObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  history         KPIHistory[]
}

// ============================================
// HISTORIAL DE MEDICIONES KPI
// ============================================
model KPIHistory {
  id              String   @id @default(cuid())
  kpiId           String
  value           Float
  date            DateTime @default(now())
  notes           String?
  createdAt       DateTime @default(now())

  kpi             CorporateKPI @relation(fields: [kpiId], references: [id], onDelete: Cascade)
}

// ============================================
// PLANES DE ACCIÓN
// ============================================
model ActionPlan {
  id              String   @id @default(cuid())
  objectiveId     String
  strategyId      String?
  corporateGoalId String?
  code            String   // Código automático
  name            String
  description     String?
  responsibleId   String?  // Empleado responsable
  teamId          String?  // Equipo asignado
  startDate       DateTime
  endDate         DateTime
  status          String   @default("pending") // pending, in_progress, completed, cancelled, delayed
  budget          Float?
  spentBudget     Float    @default(0)
  progress        Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  objective       StrategicObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  strategy        CorporateStrategy? @relation(fields: [strategyId], references: [id])
  corporateGoal   CorporateGoal? @relation(fields: [corporateGoalId], references: [id])
  team            Team? @relation(fields: [teamId], references: [id])
  responsible     Employee? @relation(fields: [responsibleId], references: [id])
  
  goals           ActionPlanGoal[]
  strategies      ActionPlanStrategy[]
  kpis            ActionPlanKPI[]
  assignments     EmployeeActionPlan[]
  tasks           Task[]
}

// ============================================
// METAS DE PLAN DE ACCIÓN
// ============================================
model ActionPlanGoal {
  id              String   @id @default(cuid())
  actionPlanId    String
  description     String
  indicator       String
  targetValue     Float
  currentValue    Float    @default(0)
  unit            String?
  progress        Float    @default(0)
  status          String   @default("on_track")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  actionPlan      ActionPlan @relation(fields: [actionPlanId], references: [id], onDelete: Cascade)
}

// ============================================
// ESTRATEGIAS DE PLAN DE ACCIÓN
// ============================================
model ActionPlanStrategy {
  id              String   @id @default(cuid())
  actionPlanId    String
  description     String
  type            String   @default("execution")
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  actionPlan      ActionPlan @relation(fields: [actionPlanId], references: [id], onDelete: Cascade)
}

// ============================================
// KPI DE PLAN DE ACCIÓN
// ============================================
model ActionPlanKPI {
  id              String   @id @default(cuid())
  actionPlanId    String
  name            String
  formula         String?
  currentValue    Float    @default(0)
  targetValue     Float    @default(100)
  unit            String?
  frequency       String   @default("monthly")
  trafficLight    String   @default("green")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  actionPlan      ActionPlan @relation(fields: [actionPlanId], references: [id], onDelete: Cascade)
}

// ============================================
// EQUIPOS DE TRABAJO
// ============================================
model Team {
  id              String   @id @default(cuid())
  strategicPlanId String
  name            String
  leaderId        String?  @unique // Empleado líder (uno a uno opcional)
  area            String?
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  strategicPlan   StrategicPlan @relation(fields: [strategicPlanId], references: [id], onDelete: Cascade)
  leader          Employee? @relation("TeamLeader", fields: [leaderId], references: [id])
  members         Employee[] @relation("TeamMember")
  actionPlans     ActionPlan[]
}

// ============================================
// EMPLEADOS
// ============================================
model Employee {
  id              String   @id @default(cuid())
  strategicPlanId String
  teamId          String?
  name            String
  position        String?
  email           String?
  phone           String?
  avatar          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  strategicPlan   StrategicPlan @relation(fields: [strategicPlanId], references: [id], onDelete: Cascade)
  team            Team? @relation("TeamMember", fields: [teamId], references: [id])
  ledTeam         Team?  @relation("TeamLeader")
  responsibleFor  ActionPlan[]
  assignments     EmployeeActionPlan[]
  individualKPIs  EmployeeKPI[]
}

// ============================================
// ASIGNACIÓN EMPLEADO - PLAN DE ACCIÓN
// ============================================
model EmployeeActionPlan {
  id              String   @id @default(cuid())
  employeeId      String
  actionPlanId    String
  role            String   @default("member") // leader, member, collaborator
  assignedAt      DateTime @default(now())

  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  actionPlan      ActionPlan @relation(fields: [actionPlanId], references: [id], onDelete: Cascade)
}

// ============================================
// KPI INDIVIDUALES DE EMPLEADOS
// ============================================
model EmployeeKPI {
  id              String   @id @default(cuid())
  employeeId      String
  name            String
  targetValue     Float
  currentValue    Float    @default(0)
  unit            String?
  progress        Float    @default(0)
  status          String   @default("on_track")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ============================================
// TAREAS (opcional, para detalles de planes)
// ============================================
model Task {
  id              String   @id @default(cuid())
  actionPlanId    String
  title           String
  description     String?
  assignedTo      String?  // Empleado ID
  dueDate         DateTime?
  status          String   @default("pending") // pending, in_progress, completed
  priority        String   @default("medium") // low, medium, high, urgent
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  actionPlan      ActionPlan @relation(fields: [actionPlanId], references: [id], onDelete: Cascade)
}

// ============================================
// ALERTAS
// ============================================
model Alert {
  id              String   @id @default(cuid())
  strategicPlanId String
  type            String   // deadline, risk, milestone, budget
  severity        String   @default("medium") // low, medium, high, critical
  title           String
  message         String
  relatedEntity   String?  // ID de la entidad relacionada
  entityType      String?  // objective, actionPlan, kpi, etc.
  isRead          Boolean  @default(false)
  isResolved      Boolean  @default(false)
  createdAt       DateTime @default(now())
  resolvedAt      DateTime?

  strategicPlan   StrategicPlan @relation(fields: [strategicPlanId], references: [id], onDelete: Cascade)
}

// ============================================
// BACKUPS
// ============================================
model Backup {
  id              String   @id @default(cuid())
  strategicPlanId String
  name            String
  data            String   // JSON string del backup
  createdAt       DateTime @default(now())

  strategicPlan   StrategicPlan @relation(fields: [strategicPlanId], references: [id], onDelete: Cascade)
}

// ============================================
// SIMULACIÓN DE ESCENARIOS
// ============================================
model Scenario {
  id              String   @id @default(cuid())
  strategicPlanId String
  name            String
  description     String?
  data            String   // JSON string con configuración del escenario
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  strategicPlan   StrategicPlan @relation(fields: [strategicPlanId], references: [id], onDelete: Cascade)
}
